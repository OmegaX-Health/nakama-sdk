{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nakama.health/schemas/robinhood-deployment-v1.json",
  "title": "Nakama Robinhood deployment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "network",
    "chainId",
    "caip2",
    "protocolRelease",
    "sourceCommit",
    "artifactBundleSha256",
    "deploymentTransaction",
    "deploymentBlock",
    "deploymentBlockHash",
    "contracts",
    "settlementAsset",
    "verified",
    "auditStatus",
    "auditReportSha256",
    "releaseApprovalSha256"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["unconfigured", "deployed"] },
    "network": { "enum": ["mainnet", "testnet"] },
    "chainId": { "enum": [4663, 46630] },
    "caip2": { "enum": ["eip155:4663", "eip155:46630"] },
    "protocolRelease": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/nonEmptyString" }]
    },
    "sourceCommit": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/gitCommit" }]
    },
    "artifactBundleSha256": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
    },
    "deploymentTransaction": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/bytes32" }]
    },
    "deploymentBlock": {
      "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 1 }]
    },
    "deploymentBlockHash": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/bytes32" }]
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assetRegistry": { "$ref": "#/$defs/contractDeployment" },
        "templateRegistry": { "$ref": "#/$defs/contractDeployment" },
        "poolRegistry": { "$ref": "#/$defs/contractDeployment" },
        "factory": { "$ref": "#/$defs/contractDeployment" },
        "program": { "$ref": "#/$defs/contractDeployment" },
        "vault": { "$ref": "#/$defs/contractDeployment" },
        "membershipRegistry": { "$ref": "#/$defs/contractDeployment" },
        "decisionModule": { "$ref": "#/$defs/contractDeployment" },
        "requestManager": { "$ref": "#/$defs/contractDeployment" },
        "settlementModule": { "$ref": "#/$defs/contractDeployment" },
        "agentAuthorizationRegistry": { "$ref": "#/$defs/contractDeployment" },
        "safetyGuardian": { "$ref": "#/$defs/contractDeployment" }
      }
    },
    "settlementAsset": { "$ref": "#/$defs/settlementAsset" },
    "verified": { "type": "boolean" },
    "auditStatus": { "enum": ["unaudited", "audited"] },
    "auditReportSha256": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
    },
    "releaseApprovalSha256": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "network": { "const": "mainnet" } } },
      "then": {
        "properties": {
          "chainId": { "const": 4663 },
          "caip2": { "const": "eip155:4663" }
        }
      },
      "else": {
        "properties": {
          "chainId": { "const": 46630 },
          "caip2": { "const": "eip155:46630" }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "unconfigured" } } },
      "then": {
        "properties": {
          "protocolRelease": { "type": "null" },
          "sourceCommit": { "type": "null" },
          "artifactBundleSha256": { "type": "null" },
          "deploymentTransaction": { "type": "null" },
          "deploymentBlock": { "type": "null" },
          "deploymentBlockHash": { "type": "null" },
          "contracts": { "maxProperties": 0 },
          "verified": { "const": false },
          "auditStatus": { "const": "unaudited" },
          "auditReportSha256": { "type": "null" },
          "releaseApprovalSha256": { "type": "null" }
        }
      },
      "else": {
        "required": [
          "protocolRelease",
          "sourceCommit",
          "artifactBundleSha256",
          "deploymentTransaction",
          "deploymentBlock",
          "deploymentBlockHash"
        ],
        "properties": {
          "protocolRelease": { "$ref": "#/$defs/nonEmptyString" },
          "sourceCommit": { "$ref": "#/$defs/gitCommit" },
          "artifactBundleSha256": { "$ref": "#/$defs/sha256" },
          "deploymentTransaction": { "$ref": "#/$defs/bytes32" },
          "deploymentBlock": { "type": "integer", "minimum": 1 },
          "deploymentBlockHash": { "$ref": "#/$defs/bytes32" },
          "contracts": {
            "required": [
              "assetRegistry",
              "templateRegistry",
              "poolRegistry",
              "factory",
              "program",
              "vault",
              "membershipRegistry",
              "decisionModule",
              "requestManager",
              "settlementModule",
              "agentAuthorizationRegistry",
              "safetyGuardian"
            ]
          },
          "verified": { "const": true }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "bytes32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "contractDeployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractName",
        "address",
        "abiSha256",
        "runtimeBytecodeHash",
        "verificationUrl"
      ],
      "properties": {
        "contractName": {
          "enum": [
            "AssetRegistry",
            "TemplateRegistry",
            "PoolRegistry",
            "NakamaFactory",
            "ProtectionProgram",
            "PoolVault",
            "MembershipRegistry",
            "DecisionModule",
            "ClaimManager",
            "SettlementModule",
            "AgentAuthorizationRegistry",
            "SafetyGuardian"
          ]
        },
        "address": { "$ref": "#/$defs/address" },
        "abiSha256": { "$ref": "#/$defs/sha256" },
        "runtimeBytecodeHash": { "$ref": "#/$defs/bytes32" },
        "verificationUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "settlementAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network",
        "chainId",
        "caip2",
        "address",
        "name",
        "symbol",
        "decimals",
        "status"
      ],
      "properties": {
        "network": { "enum": ["mainnet", "testnet"] },
        "chainId": { "enum": [4663, 46630] },
        "caip2": { "enum": ["eip155:4663", "eip155:46630"] },
        "address": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/address" }]
        },
        "name": { "const": "Global Dollar" },
        "symbol": { "const": "USDG" },
        "decimals": { "const": 6 },
        "status": { "enum": ["verified", "unconfigured"] }
      }
    }
  }
}
